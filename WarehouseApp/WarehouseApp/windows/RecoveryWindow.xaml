<Window x:Class="WarehouseApp.RecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад - Восстановление пароля" Height="480" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#F5F6FA">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Background" Value="#2980B9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HintLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4,2,0,0"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text=" Восстановление пароля" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBox x:Name="RecEmail"/>
            <TextBlock Text="Email, указанный при регистрации" Style="{StaticResource HintLabel}"/>

            <Button Content="Отправить код" Click="SendCode_Click" Margin="0,15,0,10"/>

            <StackPanel x:Name="VerifyPanel" Visibility="Collapsed">
                <TextBox x:Name="RecCode"/>
                <TextBlock Text="Введите 6-значный код из письма" Style="{StaticResource HintLabel}"/>

                <PasswordBox x:Name="NewPassword" Margin="0,4,0,0"/>
                <TextBlock Text="Введите новый пароль" Style="{StaticResource HintLabel}"/>

                <Button Content="Сменить пароль" Click="ResetPassword_Click" Margin="0,10,0,5"/>
            </StackPanel>

            <TextBlock x:Name="RecMsg" Foreground="#2980B9" TextAlignment="Center" Margin="0,10"/>

            <TextBlock Text="← Назад к авторизации" Foreground="#2980B9" HorizontalAlignment="Center" Cursor="Hand" MouseDown="GoToLogin" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Window>