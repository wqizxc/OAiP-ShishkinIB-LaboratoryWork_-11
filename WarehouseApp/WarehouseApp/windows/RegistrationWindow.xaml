<Window x:Class="WarehouseApp.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад - Регистрация" Height="620" Width="480" 
        WindowStartupLocation="CenterScreen" Background="#F5F6FA">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Background" Value="#2ECC71"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="HintLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4,2,0,0"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="📝 Регистрация сотрудника" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBox x:Name="RegFirstName"/>
                <TextBlock Text="Введите имя" Style="{StaticResource HintLabel}"/>

                <TextBox x:Name="RegLastName"/>
                <TextBlock Text="Введите фамилию" Style="{StaticResource HintLabel}"/>

                <DatePicker x:Name="RegDOB" Margin="0,4,0,0"/>
                <TextBlock Text="Выберите дату рождения" Style="{StaticResource HintLabel}"/>

                <TextBox x:Name="RegEmail"/>
                <TextBlock Text="Введите Email" Style="{StaticResource HintLabel}"/>

                <TextBox x:Name="RegPhone"/>
                <TextBlock Text="Введите телефон (+7...)" Style="{StaticResource HintLabel}"/>

                <TextBox x:Name="RegPosition"/>
                <TextBlock Text="Укажите должность" Style="{StaticResource HintLabel}"/>

                <PasswordBox x:Name="RegPassword"/>
                <TextBlock Text="Мин. 6 символов, заглавная буква + цифра" Style="{StaticResource HintLabel}"/>

                <Button Content="Зарегистрироваться" Click="Register_Click" Margin="0,15,0,10"/>

                <TextBlock x:Name="RegMsg" Foreground="#27AE60" TextAlignment="Center" Margin="0,8"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock Text="Уже есть аккаунт?" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                    <TextBlock Text=" Войти" Foreground="#2980B9" Cursor="Hand" MouseDown="GoToLogin"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>