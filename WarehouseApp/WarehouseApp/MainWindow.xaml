<Window x:Class="WarehouseApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад - Авторизация" Height="420" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#F5F6FA">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HintLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4,2,0,0"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text=" Авторизация" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBox x:Name="LoginEmail"/>
            <TextBlock Text="Введите Email" Style="{StaticResource HintLabel}"/>

            <PasswordBox x:Name="LoginPassword"/>
            <TextBlock Text="Введите пароль" Style="{StaticResource HintLabel}"/>

            <Button Content="Войти" Click="Login_Click" Margin="0,15,0,10"/>

            <TextBlock x:Name="LoginMsg" Foreground="#E74C3C" TextAlignment="Center" Margin="0,8"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Text="Нет аккаунта?" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                <TextBlock Text=" Зарегистрироваться" Foreground="#2980B9" Cursor="Hand" MouseDown="GoToRegistration"/>
            </StackPanel>

            <TextBlock Text="Забыли пароль?" Foreground="#2980B9" HorizontalAlignment="Center" Cursor="Hand" MouseDown="GoToRecovery" Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>